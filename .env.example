# ==============================================================================
# KubeOps-AI — Environment Configuration Template
# ==============================================================================
# Copy this file to .env and fill in the values.
#
#   cp .env.example .env
#
# SECURITY: Never commit the .env file to version control.
# ==============================================================================

# --------------------------------------------------------------------------
# Google Gemini API Key (REQUIRED)
# --------------------------------------------------------------------------
# Obtain from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-gemini-api-key-here

# --------------------------------------------------------------------------
# Kubernetes Configuration (OPTIONAL)
# --------------------------------------------------------------------------
# Path to your kubeconfig file. Defaults to ~/.kube/config if not set.
# When running inside a Kubernetes pod, in-cluster config is used automatically.
# KUBECONFIG=/path/to/your/kubeconfig
